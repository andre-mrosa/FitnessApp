@page "/athletes"
@inject HttpClient Http
@using System.Net.Http.Json
@using MudBlazor
@using Shared.DTOs

<PageTitle>Athletes List</PageTitle>

<NavLink href="athletes/create" class="btn btn-primary mb-3">Criar Atleta</NavLink>

@if (mensagemErro != null)
{
    <div class="alert alert-danger">@mensagemErro</div>
}
else if (athletesList == null)
{
    <p><em>A carregar atletas da API...</em></p>
}
else if (!athletesList.Any())
{
    <div class="alert alert-info">Não existem atletas registados.</div>
}
else
{
    <MudTable Items="@athletesList" Hover="true" Striped="true" Elevation="1">
        <HeaderContent>
            <MudTh>Nome</MudTh>
            <MudTh>Data de Nascimento</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Nome">@context.Name</MudTd>
            <MudTd DataLabel="Data de Nascimento">@context.BirthDate.ToShortDateString()</MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager HideRowsPerPage="false"/>
        </PagerContent>
    </MudTable>

    @* <table class="table table-striped table-hover mt-3">
        <thead class="table-dark">
            <tr>
                <th>Nome</th>
                <th>Data de Nascimento</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var athlete in athletesList)
            {
                <tr>
                    <td>@athlete.Name</td>
                    <td>@athlete.BirthDate.ToShortDateString()</td>
                </tr>
            }
        </tbody>
    </table> *@
}

@code {
    private List<AthleteDTO>? athletesList;
    private string? mensagemErro;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            athletesList = await Http.GetFromJsonAsync<List<AthleteDTO>>("api/athletes");
        }
        catch (Exception ex)
        {
            mensagemErro = $"Não foi possível carregar os dados: {ex.Message}";
            Console.WriteLine(ex);
        }
    }
}